TDX_BASE_URL=https://yourorg.teamdynamix.com/TDWebApi/api
TDX_BEID=your-beid-guid
TDX_WEB_SERVICES_KEY=your-web-services-key-guid
TDX_APP_ID=123
TDX_ASSETS_APP_ID=456
TDX_KB_APP_ID=789

# HTTP Wrapper Configuration for Public Deployment
MCP_HTTP_PORT=3000
MCP_API_KEY=your-secure-api-key

# Node Environment
NODE_ENV=production

# Modification Tools Security
# Set to "true" to enable create/update/delete/feed operations
# Default is disabled for safety - 27 modification tools require this flag
ALLOW_MODIFICATIONS=false

# TDX API Rate Limiting
# Enforces TDX's 100 calls per 60 seconds rate limit
# Set to "false" to disable rate limiting (not recommended)
TDX_RATE_LIMIT_ENABLED=true

# Number of API calls allowed per window (default: 100 per TDX's limit)
TDX_RATE_LIMIT_CALLS=100

# Rate limit window duration in milliseconds (default: 60000 = 60 seconds)
TDX_RATE_LIMIT_WINDOW_MS=60000

# Burst capacity multiplier: max tokens = callsPerWindow * multiplier
# Default: 1.5 = up to 150 concurrent tokens for handling spikes
TDX_RATE_LIMIT_BURST_CAPACITY_MULTIPLIER=1.5

# Maximum time (milliseconds) a request can wait in the rate limit queue
# Default: 300000 = 5 minutes. Requests exceeding this timeout are rejected (429)
TDX_RATE_LIMIT_QUEUE_TIMEOUT_MS=300000