{
  "swagger": "2.0",
  "info": {
    "title": "TDX MCP Connector",
    "description": "Model Context Protocol (MCP) connector for TeamDynamix REST API. Enables AI-assisted IT service management with 43 tools across tickets, assets, CMDB, knowledge base, and more.",
    "version": "1.0.0",
    "contact": {
      "name": "TDX MCP Support",
      "url": "https://github.com/PascoBOCC-IT-DBA/PascoBOCC_TDX_MCP_Connector"
    }
  },
  "host": "tdx-mcp-dev-bxcx3x.gentlestone-f466d6e8.eastus.azurecontainerapps.io",
  "basePath": "/",
  "schemes": [
    "https"
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "securityDefinitions": {
    "api_key": {
      "type": "apiKey",
      "name": "x-api-key",
      "in": "header",
      "description": "API Key for TDX MCP authentication"
    }
  },
  "paths": {
    "/mcp": {
      "post": {
        "summary": "Invoke MCP Server",
        "description": "Execute MCP JSON-RPC 2.0 commands against the TDX MCP server (initialize, tools/list, tools/call, notifications)",
        "operationId": "InvokeServer",
        "security": [
          {
            "api_key": []
          }
        ],
        "parameters": [
          {
            "name": "request",
            "in": "body",
            "description": "Complete MCP JSON-RPC 2.0 request payload",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "jsonrpc": {
                  "type": "string",
                  "example": "2.0"
                },
                "id": {
                  "type": "integer",
                  "example": 1
                },
                "method": {
                  "type": "string",
                  "example": "tools/list"
                },
                "params": {
                  "type": "object",
                  "example": {}
                }
              },
              "required": ["jsonrpc", "method"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful MCP response",
            "schema": {
              "$ref": "#/definitions/MCPResponse"
            }
          },
          "400": {
            "description": "Invalid JSON-RPC request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    }
  },
  "definitions": {
    "MCPRequest": {
      "type": "object",
      "required": [
        "jsonrpc",
        "method"
      ],
      "properties": {
        "jsonrpc": {
          "type": "string",
          "example": "2.0",
          "description": "JSON-RPC version (always 2.0)"
        },
        "id": {
          "description": "Request ID for matching responses (string or number, omit for notifications)",
          "example": 1
        },
        "method": {
          "type": "string",
          "example": "initialize",
          "description": "MCP method: initialize, tools/list, tools/call, notifications/*, etc."
        },
        "params": {
          "type": "object",
          "description": "Method-specific parameters",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "MCPResponse": {
      "type": "object",
      "properties": {
        "jsonrpc": {
          "type": "string",
          "example": "2.0"
        },
        "id": {
          "description": "Matches request ID"
        },
        "result": {
          "type": "object",
          "description": "Result object (method-dependent)",
          "additionalProperties": true
        },
        "error": {
          "type": "object",
          "properties": {
            "code": {
              "type": "integer"
            },
            "message": {
              "type": "string"
            }
          }
        }
      },
      "additionalProperties": false
    }
  },
  "x-ms-connector-metadata": [
    {
      "propertyName": "Website",
      "propertyValue": "https://github.com/PascoBOCC-IT-DBA/PascoBOCC_TDX_MCP_Connector"
    },
    {
      "propertyName": "Privacy policy",
      "propertyValue": "https://github.com/PascoBOCC-IT-DBA/PascoBOCC_TDX_MCP_Connector"
    },
    {
      "propertyName": "Categories",
      "propertyValue": [
        "IT Operations"
      ]
    }
  ]
}
