# TDX MCP Connector Environment Configuration
# 
# Copy this file to /opt/tdx-mcp/.env and update with your actual values
# Permissions should be: 600 (readable only by tdx-mcp user)
#
# Generated: 2026-07-20
# Server: 10.210.1.38:3000

################################################################################
# TDX API Configuration
################################################################################

# TDX Web API Base URL
# This is the endpoint for the TeamDynamix REST API
TDX_BASE_URL=https://service.pascocountyfl.net/TDXWebApi/api

# Business Environment ID
# Typically 1 for single-environment deployments
TDX_BEID=1

# TDX Web Services Key
# Used for API authentication - obtain from TDX Administrator
TDX_WEB_SERVICES_KEY=your_web_services_key_here

# Application IDs for different tool modules
# Each app has its own security zone and permissions
TDX_APP_ID=your_tdx_app_id_here
TDX_ASSETS_APP_ID=your_tdx_assets_app_id_here
TDX_KB_APP_ID=your_tdx_kb_app_id_here

################################################################################
# HTTP Server Configuration
################################################################################

# HTTP Port
# The port on which the HTTP wrapper listens
# Used when running with npm start:http or http-wrapper.js
MCP_HTTP_PORT=3000

# Alternative PORT variable (same as MCP_HTTP_PORT)
PORT=3000

# Node.js Environment
# Use "production" for deployments, "development" for debugging
NODE_ENV=production

################################################################################
# HTTP API Security
################################################################################

# API Key for HTTP access
# Optional key for authenticating HTTP requests to /mcp endpoint
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If set, include as "X-API-Key" header in HTTP requests
MCP_API_KEY=your_secure_api_key_here

# Allow Unauth Initialize
# If true, allows initialize request without API key
# Set to false for security in production
MCP_ALLOW_UNAUTH_INITIALIZE=false

################################################################################
# Tool Access Control
################################################################################

# Allow Modifications
# false (default) = Only read-only tools (get, search, list - 17 tools)
# true = Also enable modification tools (create, update, delete - 26 additional tools)
# 
# Recommendation:
#   - Start with false for safe exploration
#   - Enable true only if modification operations are needed
#   - Requires strong API key protection if enabled
ALLOW_MODIFICATIONS=false

################################################################################
# Request Timeouts
################################################################################

# Global default timeout for all MCP requests (milliseconds)
# Default: 60000 (60 seconds)
# Increase if tool operations are timing out
MCP_REQUEST_TIMEOUT_MS=60000

# Timeout for initialize request (milliseconds)
# MCP server startup/handshake
# Default: 30000 (30 seconds)
MCP_INIT_TIMEOUT_MS=30000

# Timeout for tools/list request (milliseconds)
# Fetching available tools list
# Default: 30000 (30 seconds)
MCP_TOOLS_LIST_TIMEOUT_MS=30000

# Timeout for tools/call request (milliseconds)
# Individual tool execution
# Default: 180000 (3 minutes) - required for long-running queries
MCP_TOOLS_CALL_TIMEOUT_MS=180000

################################################################################
# Logging & Debugging
################################################################################

# Debug mode
# Set to "*" to enable all debug output
# Set specific modules: "http,mcp,tdx"
# Leave empty to disable debug logging
# DEBUG=

# Log Level
# Options: error, warn, info, debug, trace
# Default: info
LOG_LEVEL=info

################################################################################
# Optional: Advanced Configuration
################################################################################

# MCP Subprocess idle timeout (milliseconds)
# How long to keep the MCP subprocess alive after inactivity
# Default: 300000 (5 minutes)
# MCP_SUBPROCESS_IDLE_TIMEOUT=300000

# HTTP Server Keep-Alive Timeout (milliseconds)
# Default: 65000
# HTTP_KEEPALIVE_TIMEOUT=65000

# Max Request Body Size
# Default: 10mb
# HTTP_MAX_REQUEST_SIZE=10mb

################################################################################
# Notes
################################################################################

# - This file is git-ignored; never commit actual credentials
# - After updating this file, restart the service:
#   sudo systemctl restart tdx-mcp
# - Verify with: sudo systemctl status tdx-mcp
# - Check logs: sudo journalctl -u tdx-mcp -f

# - Generate a secure API key:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# - Rotate credentials regularly for security
# - Keep a backup of this file in a secure location
